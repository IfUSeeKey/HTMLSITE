block variables
    - var title = "Экскурсии по городу"
    - var descs = [{ menuItem: "Ботанический сад", pict: "botan_sad.png", firstP: "Ботанический сад - крупнейший ботанический сад на Дальнем Востоке России.", secondP: "Сад создан в 1949 году. Ботанический сад-институт является особо охраняемой природной территорией федерального значения. Территория сада (169 га) на 90% занята типичными для зоны смешанных широколиственно-хвойных лесов востока Азии, малонарушенными естественными лесными сообществами из кедра корейского, пихты цельнолистной, дуба монгольского, липы амурской, ясеня маньчжурского, диморфанта семилопастного и других видов деревьев. Протяженность экологической тропы сада около 2 км, здесь можно встретить 216 видов растений."}]
