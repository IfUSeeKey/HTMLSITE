mixin createTable(header, data)
    table.table(border="1" cellspacing="0" cellpadding="3")
        thead.table__header
            tr.table__row
                each colonka in header 
                    th.table__cell.table__cell--header= colonka
        
        tbody.table__body
            each stroka in data
                tr.table__row
                    each value in Object.values(stroka)
                        td.table__cell= value