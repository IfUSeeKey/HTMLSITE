colorText = #000000

columnColor()
  &:nth-child(odd)
    background-color royalblue
    color white
  &:nth-child(even)
    background-color grey
    color black

.table
  width 100%
  font-size 14px
  color colorText
  margin 15px 0

  &__header
    font-weight bold

  &__row
    text-align left

  &__cell
    columnColor()

    &--header
      text-align center
      font-weight bold
    




html
  color colorText

nav
  back(0)
  text-align right

  & a
    display inline-block
    padding 1%
    color colorText
    text-decoration none
        
    &:hover
    &.active
      background-color royalblue
      color #f8f8f8   

div.gallery
  margin 10px auto
  display grid
  grid-template-columns repeat(4, 1fr)
  grid-template-rows 150px 150px
  gap 5px

  & .gallery_item--big
    grid-area 1 / 1 / 3 / 3

  & .gallery_item--wide
    grid-area 1 / 3 / 2 / 5

  & img
    width 100%
    height @width
    overflow hidden
    display block

    &:hover
      transform scale(1.1)

div.body
  display flex
  gap 5px
  justify-content center
  padding 20px

  & img
    width 100%

    &:hover
      transform scale(1.1)

  & h3
    margin auto
    text-align center

  & div.left-content
  & div.right-content
    display grid
    gap 5px
    flex 0 0 12%

    & img
      width 100%

    & p
      margin auto
      text-align center

  & div.middle-content
    display flex
    justify-content center
    gap 20px
    

    & .cards-container
      display flex
      gap 20px
      flex-wrap wrap
      justify-content center

    & p
      text-align justify

    & h3
      padding 5px

    & div.big-card
      border 2px solid
      border-radius 15px
      padding 20px
      overflow hidden
      display flex
      flex-direction column

      & h3
        text-align center
        font-size 18px
        font-weight bold

      & .text-content
        text-align justify
        margin 15px 0
        padding 0 10px
        font-size 14px
        
      & .image-container
        width 100%
        border-radius 25px
        margin 15px 0
        overflow hidden
        display flex
        align-items center
        justify-content center
        
        & img
          width 100%
          height 100%
          object-fit cover
        
          &:hover
            transform scale(1.1)


      & .big-card__big-card-main--first
        display flex
        flex-direction column
      
      & .big-card__big-card-main--second
        display flex
        flex-direction column
        gap 10px

      // Контейнер для кнопок
      & .button-container
        margin-top 10px

        &.button-right
          display flex
          justify-content flex-end

        &.button-left
          display flex
          justify-content flex-start

      & button
        background-color royalblue
        color white
        border-radius 5px
        padding 8px 15px
        font-weight bold
        font-size 14px

      &__big-card-main--first
        display grid
        grid-template-columns 1fr 1fr
        gap 5px

        & div.big-card-main__text
          display flex
          flex-direction column

      &__big-card-main--second
        display grid
        grid-template-columns 1fr 2fr
        gap 5px

footer
  background-color royalblue
  color white
  & h4
    padding 10px

@media (max-width: 600px)
  div.gallery
    grid-template-rows 50px 50px

  div.body
    flex-direction column

    & div.middle-content
      & .cards-container
        flex-direction column
        align-items center

      & div.big-card
        width 100%
        max-width 350px

@media (min-width: 600px) and (max-width: 1000px)
  div.gallery
    grid-template-rows 100px 100px


